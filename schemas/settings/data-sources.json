{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://raw.githubusercontent.com/recyclarr/recyclarr/master/schemas/settings/data_source.json",
  "type": "array",
  "title": "Array of configurable data sources",
  "items": {
    "anyOf": [{ "$ref": "#/definitions/local" }, { "$ref": "#/definitions/repository" }]
  },
  "definitions": {
    "local": {
      "type": "object",
      "required": ["path", "service"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "title": "Path to a directory containing the expected data files"
        },
        "service": {
          "type": "string",
          "enum": ["radarr", "sonarr"],
          "title": "Service type that the data files are intended for and compatible with"
        }
      }
    },
    "repository": {
      "type": "object",
      "required": ["clone_url"],
      "additionalProperties": false,
      "properties": {
        "clone_url": {
          "type": "string",
          "title": "Git clone URL for the repository",
          "format": "uri"
        },
        "reference": {
          "type": "string",
          "title": "Optional branch name or SHA1 commit hash to check out"
        }
      }
    }
  }
}
