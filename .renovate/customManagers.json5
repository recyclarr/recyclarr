{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      description: "Update GitVersion versionSpec in GitHub Actions workflows",
      customType: "regex",
      managerFilePatterns: ["/^\\.github/.+\\.ya?ml$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*versionSpec:\\s*(?<currentValue>.+)",
      ],
    },
    {
      description: "Update TargetFramework in MSBuild props files",
      customType: "regex",
      managerFilePatterns: ["/\\.props$/"],
      matchStrings: [
        "<TargetFramework>net(?<currentValue>\\d+\\.\\d+)</TargetFramework>",
      ],
      depNameTemplate: "dotnet-sdk",
      datasourceTemplate: "dotnet-version",
      extractVersionTemplate: "^(?<version>\\d+\\.\\d+)",
    },
    {
      description: "Update dotnet-version input in setup-dotnet action",
      customType: "regex",
      managerFilePatterns: ["/^\\.github/.+\\.ya?ml$/"],
      matchStrings: ["dotnet-version:\\s*(?<currentValue>\\d+\\.\\d+)\\.x"],
      depNameTemplate: "dotnet-sdk",
      datasourceTemplate: "dotnet-version",
      extractVersionTemplate: "^(?<version>\\d+\\.\\d+)",
    },
    {
      description: "Update Qodana linter image in qodana.yaml",
      customType: "regex",
      managerFilePatterns: ["/^qodana\\.ya?ml$/"],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\nlinter:\\s*"[^:]+:(?<currentValue>[^"]+)"',
      ],
    },
  ],
}
