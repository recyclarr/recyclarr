{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  automergeStrategy: "rebase",
  packageRules: [
    {
      description: "Auto-merge all patch updates",
      matchUpdateTypes: ["patch"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
    {
      description: "Auto-merge NuGet patch updates with release age gate",
      matchDatasources: ["nuget"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["patch"],
      minimumReleaseAge: "1 day",
      ignoreTests: false,
    },
    {
      description: "Auto-merge GitHub Actions patch and digest updates",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["patch", "digest"],
      ignoreTests: true,
    },
    {
      description: "Auto-merge .NET Docker images - patch and digest only",
      matchDatasources: ["docker"],
      matchPackagePatterns: ["^mcr\\.microsoft\\.com/dotnet/"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["patch", "digest"],
      ignoreTests: false,
    },
    {
      description: "Require manual review for release-critical actions",
      matchManagers: ["github-actions"],
      matchPackageNames: [
        "softprops/action-gh-release",
        "actions/create-github-app-token",
      ],
      automerge: false,
    },
  ],
}
