{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "NuGet package presentation configuration",
      matchDatasources: ["nuget"],
      matchUpdateTypes: ["patch", "minor", "major"],
      prBodyColumns: [
        "Package",
        "Change",
        "Age",
        "Adoption",
        "Passing",
        "Confidence",
        "Pending",
      ],
      minimumReleaseAge: "5 days",
    },
    {
      // dotnet-version datasource doesn't mark RC/preview releases as unstable,
      // so ignoreUnstable preset doesn't work. Block pre-releases until GA.
      description: "Prevent .NET pre-release versions (RC/preview) until GA",
      matchDatasources: ["docker", "dotnet-version"],
      matchPackagePatterns: ["^mcr\\.microsoft\\.com/dotnet/", "^dotnet-sdk$"],
      allowedVersions: "!/-(rc|preview|alpha|beta)/",
    },
    {
      description: "Qodana linter image uses non-semver tags (YYYY.minor)",
      matchDatasources: ["docker"],
      matchPackageNames: ["jetbrains/qodana-dotnet"],
      versioning: "loose",
    },
    {
      description: "Add changelog URLs for GitHub Actions digest updates",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["digest"],
      prBodyNotes: ["Changelog: {{{changelogUrl}}}"],
    },
  ],
}
