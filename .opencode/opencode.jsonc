{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../AGENTS.md"],
  "formatter": {
    "csharpier": {
      "command": ["dotnet", "csharpier", "format", "$FILE"],
      "extensions": [".cs"],
    },
  },
  "lsp": {
    "csharp": {
      "disabled": true,
    },
  },
  "mcp": {
    "codanna": {
      "type": "local",
      "command": ["codanna", "--config", ".codanna/settings.toml", "serve", "--watch"],
      "enabled": true,
    },
  },
}
